<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HabiCheck.Views.ScannerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:HabiCheck.ViewModels"
    Shell.NavBarIsVisible="False"
    BackgroundColor="Black">

    <ContentPage.BindingContext>
        <vm:ScannerViewModel/>
    </ContentPage.BindingContext>

    <Grid>

        <!-- Dark textured background -->
        <BoxView Color="#1A1A1A"/>

        <!-- Grid texture overlay -->
        <Image
            Source="scan_grid.png"
            Opacity="0.15"
            Aspect="AspectFill"/>

        <!-- Top Bar -->
        <Grid
            Padding="16,52,16,0"
            VerticalOptions="Start"
            ColumnDefinitions="Auto,*,Auto"
            ZIndex="10">
            <Border
                Grid.Column="0"
                BackgroundColor="#60000000"
                WidthRequest="44" HeightRequest="44"
                StrokeShape="RoundRectangle 22" Stroke="Transparent">
                <Label Text="✕" TextColor="White" FontSize="20"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseClicked"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>

            <Border
                Grid.Column="2"
                BackgroundColor="{Binding FlashOn, Converter={StaticResource FlashColorConverter}}"
                WidthRequest="44" HeightRequest="44"
                StrokeShape="RoundRectangle 22" Stroke="Transparent">
                <Label Text="⚡" TextColor="White" FontSize="20"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleFlashCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <!-- Macro Guide Circle (center) -->
        <Grid HorizontalOptions="Center" VerticalOptions="Center" ZIndex="5">
            <Ellipse
                WidthRequest="280" HeightRequest="280"
                Stroke="White" StrokeThickness="3"
                Fill="Transparent"
                Opacity="0.6"/>
            <!-- Inner pulse ring -->
            <Ellipse
                WidthRequest="280" HeightRequest="280"
                Stroke="White" StrokeThickness="1"
                Fill="Transparent"
                Opacity="0.25"/>
            <!-- Corner brackets drawn with BoxViews -->
            <BoxView Color="White" WidthRequest="3" HeightRequest="30"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     TranslationX="0" TranslationY="0"/>
        </Grid>

        <!-- Instruction text -->
        <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="End"
            Spacing="6"
            Margin="0,0,0,160"
            IsVisible="{Binding IsScanning, Converter={StaticResource InvertBoolConverter}}"
            ZIndex="10">
            <Label Text="🔍" FontSize="32" HorizontalOptions="Center"/>
            <Label Text="Focus on the weave pattern"
                   TextColor="White" FontFamily="PoppinsSemiBold" FontSize="17"
                   HorizontalOptions="Center"/>
            <Label Text="Get close to see the fabric texture"
                   TextColor="#CCFFFFFF" FontSize="13" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Analyzing Overlay -->
        <Grid
            BackgroundColor="#99000000"
            IsVisible="{Binding IsScanning}"
            ZIndex="20">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                <ActivityIndicator
                    IsRunning="{Binding IsScanning}"
                    Color="White"
                    WidthRequest="60" HeightRequest="60"/>
                <Label Text="Analyzing fabric..."
                       TextColor="White" FontFamily="PoppinsSemiBold" FontSize="20"
                       HorizontalOptions="Center"/>
                <Label Text="Checking weave pattern &amp; fiber type"
                       TextColor="#AAFFFFFF" FontSize="13" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Bottom Controls -->
        <Grid
            VerticalOptions="End"
            Padding="40,0,40,60"
            ColumnDefinitions="Auto,*,Auto"
            IsVisible="{Binding IsScanning, Converter={StaticResource InvertBoolConverter}}"
            ZIndex="10">

            <!-- Gallery button -->
            <Border
                Grid.Column="0"
                BackgroundColor="#44FFFFFF"
                WidthRequest="52" HeightRequest="52"
                StrokeShape="RoundRectangle 26" Stroke="Transparent"
                VerticalOptions="Center">
                <Label Text="🖼️" FontSize="24"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickFromGalleryCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>

            <!-- Shutter button -->
            <Border
                Grid.Column="1"
                BackgroundColor="White"
                WidthRequest="80" HeightRequest="80"
                StrokeShape="RoundRectangle 40" Stroke="Transparent"
                HorizontalOptions="Center"
                Shadow="{Shadow Brush=White, Offset='0,4', Opacity=0.4, Radius=12}">
                <Ellipse
                    WidthRequest="64" HeightRequest="64"
                    Stroke="{StaticResource DeepSage}"
                    StrokeThickness="4"
                    Fill="Transparent"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <Ellipse.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CaptureAndScanCommand}"/>
                    </Ellipse.GestureRecognizers>
                </Ellipse>
            </Border>

            <BoxView Grid.Column="2" WidthRequest="52" HeightRequest="52" Color="Transparent"/>
        </Grid>

    </Grid>
</ContentPage>