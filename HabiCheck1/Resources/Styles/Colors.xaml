<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Base Label ────────────────────────────────── -->
    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="TextColor" Value="{StaticResource Foreground}" />
    </Style>

    <!-- ── Heading styles ────────────────────────────── -->
    <Style x:Key="H1" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{StaticResource DeepSage}" />
    </Style>

    <Style x:Key="H2" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="{StaticResource DeepSage}" />
    </Style>

    <Style x:Key="Body" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource MutedForeground}" />
    </Style>

    <!-- ── Primary Button ────────────────────────────── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource DeepSage}" />
        <Setter Property="TextColor" Value="{StaticResource Cream}" />
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ── Outline Button ────────────────────────────── -->
    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource DeepSage}" />
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="BorderColor" Value="{StaticResource SageGreen}" />
        <Setter Property="BorderWidth" Value="2" />
    </Style>

    <!-- ── Card Frame ─────────────────────────────────── -->
    <Style x:Key="Card" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource White}" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderColor" Value="Transparent" />
    </Style>

    <!-- ── Input Entry ────────────────────────────────── -->
    <Style x:Key="InputEntry" TargetType="Entry">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Foreground}" />
        <Setter Property="PlaceholderColor" Value="#B0A99A" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

</ResourceDictionary>